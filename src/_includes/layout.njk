<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}

    <title>{{ title }} | Breast Cancer Warriors Gambia</title>
    <meta name="description" content="{{ description or excerpt or 'Aiding and bringing hope to women with cancer in The Gambia.' }}">
    <meta name="theme-color" content="#C2185B">
    
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="stylesheet" href="{{ '/css/style.css' | url() }}">

    <meta property="og:title" content="{{ title }} | BCW Gambia">
    <meta property="og:description" content="{{ description or 'Support women fighting breast cancer in The Gambia.' }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:image" content="{{ site.url }}{{ og_image if og_image else '/assets/img/b-c-w-logo.png' }}">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Breast Cancer Warriors Gambia",
      "url": "{{ site.url }}",
      "logo": "{{ site.url }}/assets/img/b-c-w-logo.png",
      "taxID": "2025/C25004"
    }
    </script>
</head>

<body class="font-sans antialiased bg-white text-slate-900">

    <nav class="fixed top-0 left-0 right-0 z-50 border-b nav-glass border-slate-100">
        <div class="flex items-center justify-between h-20 px-6 mx-auto max-w-7xl">
            
            <a href="{{ '/' | url() }}" class="flex items-center group">
                <img src="{{ '/assets/img/b-c-w-logo.png' | url() }}" alt="BCW Gambia Logo" class="nav-logo">
            </a>

            <div class="items-center hidden gap-10 lg:flex">
                <a href="{{ '/' | url() }}" class="text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-warrior-pink">Home</a>
                <a href="{{ '/about/' | url() }}" class="text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-warrior-pink">About</a>
                <a href="{{ '/stories/' | url() }}" class="text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-warrior-pink">Stories</a>
                <a href="{{ '/what-we-do/' | url() }}" class="text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-warrior-pink">What we do</a>
                <a href="{{ '/contact/' | url() }}" class="text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-warrior-pink">Contact</a>
            </div>

            <div class="items-center hidden md:flex">
                <a href="{{ '/donate/' | url() }}" class="bg-warrior-pink text-white px-8 py-3 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg shadow-warrior-pink/20">
                    Donate Now
                </a>
            </div>

            <button id="menu-toggle" class="relative w-10 h-10 p-2 lg:hidden text-slate-900 focus:outline-none" aria-label="Toggle menu" aria-expanded="false">
                <div id="hamburger-icon" class="absolute inset-0 flex items-center justify-center transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                    </svg>
                </div>
                <div id="close-icon" class="absolute inset-0 flex items-center justify-center transition-all duration-300 scale-0 opacity-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </div>
            </button>
        </div>

        <div id="mobile-menu" class="bg-white lg:hidden">
            <div class="flex flex-col p-8 space-y-6 text-center">
                <a href="{{ '/' | url() }}" class="text-sm font-black tracking-widest uppercase text-slate-600">Home</a>
                <a href="{{ '/about/' | url() }}" class="text-sm font-black tracking-widest uppercase text-slate-600">About</a>
                <a href="{{ '/stories/' | url() }}" class="text-sm font-black tracking-widest uppercase text-slate-600">Stories</a>
                <a href="{{ '/what-we-do/' | url() }}" class="text-sm font-black tracking-widest uppercase text-slate-600">What We Do</a>
                <a href="{{ '/contact/' | url() }}" class="text-sm font-black tracking-widest uppercase text-slate-600">Contact</a>
                <a href="{{ '/donate/' | url() }}" class="bg-warrior-pink text-white py-4 rounded-full text-[10px] font-black uppercase tracking-widest">Donate Now</a>
            </div>
        </div>
    </nav>

    <main class="min-h-screen">
        {{ content | safe }}
    </main>

    <script src="{{ '/js/navigation.js' | url() }}" defer></script>
</body>
</html>